# Resend Email Configuration
# Get this from https://resend.com/api-keys
EXPO_PUBLIC_RESEND_API_KEY=re_YOUR_API_KEY_HERE
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# Supabase Service Role Key (needed for webhook API routes that bypass RLS)
# Get this from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Apple In-App Purchase Webhook Verification
# Set these as Supabase Edge Function secrets (supabase secrets set ...)
# APPLE_BUNDLE_ID=app.nextquark.hireswipe
# APPLE_SHARED_SECRET=your_apple_shared_secret_here
# APPLE_API_KEY=your_app_store_server_api_key_here
# APPLE_API_ISSUER_ID=your_issuer_id_here
# APPLE_ENVIRONMENT=production  (or sandbox for testing)

# Google Play RTDN Webhook Verification
# Set these as Supabase Edge Function secrets (supabase secrets set ...)
# GOOGLE_PUBSUB_VERIFICATION_TOKEN=your_random_token_here
# GOOGLE_SERVICE_ACCOUNT_KEY=your_service_account_json_here

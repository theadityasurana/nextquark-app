# Razorpay Configuration
# Get these from https://dashboard.razorpay.com/app/keys

# For Test Mode (use these while testing)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
EXPO_PUBLIC_RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

# For Production Mode (use these when going live)
# EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID_HERE
# EXPO_PUBLIC_RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

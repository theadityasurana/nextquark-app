# Razorpay Configuration
# Get these from https://dashboard.razorpay.com/app/keys

# For Test Mode (use these while testing)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
EXPO_PUBLIC_RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

# For Production Mode (use these when going live)
# EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID_HERE
# EXPO_PUBLIC_RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE

# Gmail SMTP Configuration
# Get this from https://myaccount.google.com/apppasswords
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail"
# 4. Copy the 16-character password and paste it below
EXPO_PUBLIC_GMAIL_APP_PASSWORD=your_16_character_app_password_here

# Resend Email Configuration
# Get this from https://resend.com/api-keys
EXPO_PUBLIC_RESEND_API_KEY=re_YOUR_API_KEY_HERE
